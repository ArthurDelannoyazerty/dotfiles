[global]
    monitor = 0
    follow = mouse
    
    # Geometry & placement (Matches your 5px gaps_out)
    width = 320
    origin = top-right
    offset = 5x5
    gap_size = 5
    
    # Styling (Matches Hyprland & UI configs)
    corner_radius = 0
    frame_width = 1
    separator_height = 0
    
    # Typography
    font = Iosevka Nerd Font 10
    markup = full
    format = "<b>%s</b>\n%b"
    
    # Padding
    padding = 14
    horizontal_padding = 14
    text_icon_padding = 14
    
    # Behavior
    sort = yes
    idle_threshold = 120
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    # Icons
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    
    # Mouse interaction
    mouse_left_click = do_action, close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    show_indicators = no
{
    "label": "lock",
    "action": "hyprlock",
    "text": "Lock",
    "keybind": "l"
}
{
    "label": "logout",
    "action": "hyprctl dispatch exit",
    "text": "Log Out",
    "keybind": "e"
}
{
    "label": "hibernate",
    "action": "systemctl hibernate",
    "text": "Hibernate",
    "keybind": "h"
}
{
    "label": "back",
    "action": "nohup $HOME/.config/wlogout/launch.sh main --wait >/dev/null 2>&1 &",
    "text": "Back",
    "keybind": "b"
}